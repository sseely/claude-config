    "additionalDirectories": [
      "/tmp",
      "/private/tmp",
      "/Users/scottseely/.claude",
      "/Users/scottseely/.claude/skills",
      "/Users/scottseely",
      "/Users/scottseely/.claude/rules",
      "/Users/scottseely/git/phil-elevator/public/guides",
      "/Users/scottseely/temp/github-study-guide",
      "/Users/scottseely/git/plantuml-js/.claude"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/record-turn-start.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/project-init.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.claude/post-compact-context.md"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '-- COMPACTING: verify open TODOs are committed --'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"\nimport sys, json, re\ndata = json.load(sys.stdin)\ncmd = data.get('tool_input', {}).get('command', '')\nif re.search(r'(?:^|\\n|[;&|])\\s*rm\\s+-rf\\s+/', cmd):\n    print('BLOCKED: rm -rf / is not allowed', file=sys.stderr)\n    sys.exit(2)\nif cmd.strip().startswith('sudo '):\n    print('BLOCKED: sudo requires project opt-in', file=sys.stderr)\n    sys.exit(2)\n\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-complexity.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] InstructionsLoaded\" >> ~/.claude/logs/instructions-loaded.log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-on-stop.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "autoMemoryEnabled": true,
  "agentPushNotifEnabled": true,
  "model": "claude-fable-5",
  "tui": "fullscreen"
}
