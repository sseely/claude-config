{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(chmod:*)",
      "Bash(mkdir *:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(openssl rand:*)",
      "Bash(node -e:*)",
      "Bash(python3:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(gh workflow list:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose up:*)",
      "Bash(~/.claude/hooks/quality-gate.sh:*)",
      "Bash(~/.claude/hooks/autonomous-toggle.sh on:*)",
      "Bash(~/.claude/hooks/autonomous-toggle.sh off:*)",
      "Edit(~/git/**)",
      "Write(~/git/**)",
      "Read(~/git/**)",
      "Glob(~/git/**)",
      "Grep(~/git/**)",
      "Edit(~/.claude/**)",
      "Write(~/.claude/**)",
      "Read(~/.claude/**)",
      "Glob(~/.claude/**)",
      "Grep(~/.claude/**)",
      "Edit(~/church/**)",
      "Write(~/church/**)",
      "Read(~/church/**)",
      "Glob(~/church/**)",
      "Grep(~/church/**)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Edit(~/.claude/skills/code-review/**)",
      "Bash(curl -s https://raw.githubusercontent.com/sseely-experity/claude-config/main/CLAUDE.md)",
      "Bash(curl -s https://raw.githubusercontent.com/sseely-experity/claude-config/main/rules/commits.md)",
      "Bash(curl -s https://raw.githubusercontent.com/sseely-experity/claude-config/main/settings.json)",
      "Bash(gh api:*)"
    ],
    "additionalDirectories": [
      "/tmp",
      "/private/tmp",
      "/Users/scottseely/.claude"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/record-turn-start.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-on-stop.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
